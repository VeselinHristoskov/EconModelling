        "class Point:\n",
        "    \"\"\"Simple class to represent a point in 2D space.\"\"\"\n",
        "\n",
        "    def __init__(self, x, y):\n",
        "        # __init__ is a magic method — Python calls it automatically on Point(1, 2)\n",
        "        self.x = x\n",
        "        self.y = y\n",
        "\n",
        "    def __str__(self):\n",
        "        # magic method — called automatically by print(point)\n",
        "        return f\"P<{self.x},{self.y}>\"\n",
        "\n",
        "    def __repr__(self):\n",
        "        # magic method — used to display the object inside lists / REPL\n",
        "        return self.__str__()\n",
        "\n",
        "    def __lt__(self, other):\n",
        "        # magic method — called automatically by < and list.sort()\n",
        "        return self.distance_origin() < other.distance_origin()\n",
        "\n",
        "    def distance_origin(self):\n",
        "        # regular method — called explicitly: p.distance_origin()\n",
        "        return (self.x ** 2 + self.y ** 2) ** 0.5\n",
        "\n",
        "    def distance_to(self, point):\n",
        "        # regular method — called explicitly: p1.distance_to(p2)\n",
        "        return ((self.x - point.x) ** 2 + (self.y - point.y) ** 2) ** 0.5"
